    function lib:CreateDropdown(title, ParentCanvas, options, callback)
        local Frame = Instance.new("Frame")
        Frame.Name             = "Dropdown"
        Frame.Parent           = ParentCanvas
        Frame.BackgroundColor3 = T.BG3
        Frame.BorderSizePixel  = 0
        Frame.Size             = UDim2.new(0.94, 0, 0, IsMobile and 38 or 42)
        Frame.ClipsDescendants = false
        Frame.ZIndex           = 10
        Corner(6, Frame)
        Stroke(1, T.Border, Frame)

        local TitleLbl = Instance.new("TextLabel")
        TitleLbl.Parent             = Frame
        TitleLbl.BackgroundTransparency = 1
        TitleLbl.Position           = UDim2.new(0, 12, 0, 0)
        TitleLbl.Size               = UDim2.new(0.48, 0, 1, 0)
        TitleLbl.Font               = Enum.Font.GothamMedium
        TitleLbl.Text               = title
        TitleLbl.TextColor3         = T.OffWhite
        TitleLbl.TextSize           = IsMobile and 11 or 12
        TitleLbl.TextXAlignment     = Enum.TextXAlignment.Left
        TitleLbl.ZIndex             = 11

        local SelLbl = Instance.new("TextLabel")
        SelLbl.Parent             = Frame
        SelLbl.BackgroundTransparency = 1
        SelLbl.Position           = UDim2.new(0.48, 0, 0, 0)
        SelLbl.Size               = UDim2.new(0.42, 0, 1, 0)
        SelLbl.Font               = Enum.Font.GothamMedium
        SelLbl.Text               = options[1] or ""
        SelLbl.TextColor3         = T.AccentDim
        SelLbl.TextSize           = IsMobile and 11 or 12
        SelLbl.TextXAlignment     = Enum.TextXAlignment.Right
        SelLbl.ZIndex             = 11

        local Arrow = Instance.new("TextLabel")
        Arrow.Parent             = Frame
        Arrow.BackgroundTransparency = 1
        Arrow.AnchorPoint        = Vector2.new(1, 0.5)
        Arrow.Position           = UDim2.new(1, -8, 0.5, 0)
        Arrow.Size               = UDim2.new(0, 16, 0, 16)
        Arrow.Font               = Enum.Font.GothamBold
        Arrow.Text               = "v"
        Arrow.TextColor3         = T.Dim
        Arrow.TextSize           = 12
        Arrow.ZIndex             = 11

        local DropHolder = Instance.new("Frame")
        DropHolder.Parent           = Frame
        DropHolder.BackgroundColor3 = T.BG2
        DropHolder.BorderSizePixel  = 0
        DropHolder.Position         = UDim2.new(0, 0, 1, 4)
        DropHolder.Size             = UDim2.new(1, 0, 0, 0)
        DropHolder.Visible          = false
        DropHolder.ZIndex           = 20
        DropHolder.ClipsDescendants = true
        Corner(6, DropHolder)
        Stroke(1, T.Border, DropHolder)

        local DList = Instance.new("UIListLayout")
        DList.Parent              = DropHolder
        DList.HorizontalAlignment = Enum.HorizontalAlignment.Center
        DList.SortOrder           = Enum.SortOrder.LayoutOrder
        DList.Padding             = UDim.new(0, 2)

        local DPad = Instance.new("UIPadding")
        DPad.Parent     = DropHolder
        DPad.PaddingTop = UDim.new(0, 4)
        DPad.PaddingBottom = UDim.new(0, 4)

        local HitBtn = Instance.new("TextButton")
        HitBtn.Parent             = Frame
        HitBtn.BackgroundTransparency = 1
        HitBtn.Size               = UDim2.new(1,0,1,0)
        HitBtn.Text               = ""
        HitBtn.ZIndex             = 15

        local isOpen = false
        local currentCb = callback

        local function buildOptions(opts)
            for _, child in ipairs(DropHolder:GetChildren()) do
                if child:IsA("TextButton") then child:Destroy() end
            end
            for _, opt in ipairs(opts) do
                local OBtn = Instance.new("TextButton")
                OBtn.Parent           = DropHolder
                OBtn.BackgroundColor3 = T.BG3
                OBtn.BackgroundTransparency = 1
                OBtn.BorderSizePixel  = 0
                OBtn.Size             = UDim2.new(0.94, 0, 0, IsMobile and 28 or 30)
                OBtn.Font             = Enum.Font.GothamMedium
                OBtn.Text             = opt
                OBtn.TextColor3       = T.Dim
                OBtn.TextSize         = IsMobile and 11 or 12
                OBtn.ZIndex           = 25
                Corner(4, OBtn)
                OBtn.MouseEnter:Connect(function()
                    TweenService:Create(OBtn, TweenInfo.new(0.1), {BackgroundTransparency = 0, TextColor3 = T.White}):Play()
                end)
                OBtn.MouseLeave:Connect(function()
                    TweenService:Create(OBtn, TweenInfo.new(0.1), {BackgroundTransparency = 1, TextColor3 = T.Dim}):Play()
                end)
                OBtn.MouseButton1Click:Connect(function()
                    SelLbl.Text = opt
                    isOpen = false
                    DropHolder.Visible = false
                    TweenService:Create(Arrow, TweenInfo.new(0.15), {Rotation = 0}):Play()
                    if currentCb then currentCb(opt) end
                end)
                OBtn.TouchTap:Connect(function()
                    SelLbl.Text = opt
                    isOpen = false
                    DropHolder.Visible = false
                    TweenService:Create(Arrow, TweenInfo.new(0.15), {Rotation = 0}):Play()
                    if currentCb then currentCb(opt) end
                end)
            end
        end

        buildOptions(options)

        local function getTotalH(opts) return #opts * (IsMobile and 30 or 32) + 10 end

        HitBtn.MouseButton1Click:Connect(function()
            isOpen = not isOpen
            if isOpen then
                DropHolder.Visible = true
                DropHolder.Size = UDim2.new(1, 0, 0, 0)
                TweenService:Create(DropHolder, TweenInfo.new(0.18), {Size = UDim2.new(1, 0, 0, getTotalH(options))}):Play()
                TweenService:Create(Arrow, TweenInfo.new(0.15), {Rotation = 180}):Play()
            else
                TweenService:Create(DropHolder, TweenInfo.new(0.18), {Size = UDim2.new(1, 0, 0, 0)}):Play()
                TweenService:Create(Arrow, TweenInfo.new(0.15), {Rotation = 0}):Play()
                task.delay(0.2, function() DropHolder.Visible = false end)
            end
        end)
        HitBtn.TouchTap:Connect(function()
            isOpen = not isOpen
            if isOpen then
                DropHolder.Visible = true
                DropHolder.Size = UDim2.new(1, 0, 0, 0)
                TweenService:Create(DropHolder, TweenInfo.new(0.18), {Size = UDim2.new(1, 0, 0, getTotalH(options))}):Play()
                TweenService:Create(Arrow, TweenInfo.new(0.15), {Rotation = 180}):Play()
            else
                TweenService:Create(DropHolder, TweenInfo.new(0.18), {Size = UDim2.new(1, 0, 0, 0)}):Play()
                TweenService:Create(Arrow, TweenInfo.new(0.15), {Rotation = 0}):Play()
                task.delay(0.2, function() DropHolder.Visible = false end)
            end
        end)

        local Obj = {}
        function Obj:Set(val) SelLbl.Text = val; if currentCb then currentCb(val) end end
        function Obj:Get() return SelLbl.Text end
        function Obj:Refresh(newOpts, newCb)
            options = newOpts
            if newCb then currentCb = newCb end
            buildOptions(newOpts)
            SelLbl.Text = newOpts[1] or ""
        end
        return Obj
    end

