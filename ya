function lib:CreateWindow(title)
	local UI = Instance.new("ScreenGui")
	local Main = Instance.new("Frame")
	local UICorner = Instance.new("UICorner")
	local TopBar = Instance.new("Frame")
	local Title = Instance.new("TextLabel")
	local Line = Instance.new("Frame")
	local Navigation = Instance.new("ScrollingFrame")
	local UIListLayout = Instance.new("UIListLayout")
	local UIPadding = Instance.new("UIPadding")
	local Line_2 = Instance.new("Frame")
	local ContentContainer = Instance.new("Frame")
	local ExitButton = Instance.new("ImageButton")
	local MobileCard = Instance.new("TextButton")
	local UICorner_Mobile = Instance.new("UICorner")

	-- Theme Palette for elements
	local AccentColor = Color3.fromRGB(80, 80, 255)
	local AccentColorHover = Color3.fromRGB(100, 100, 255)
	local ElementBG = Color3.fromRGB(15, 15, 15)
	local ElementBGHover = Color3.fromRGB(22, 22, 22)
	local ElementBorder = Color3.fromRGB(35, 35, 35)
	local ElementBorderHover = Color3.fromRGB(50, 50, 50)
	local TextMain = Color3.fromRGB(255, 255, 255)
	local TextMuted = Color3.fromRGB(200, 200, 200)

	local TweenService = game:GetService("TweenService")

	local function addStroke(parent, color, thickness)
		local stroke = Instance.new("UIStroke")
		stroke.Color = color or ElementBorder
		stroke.Thickness = thickness or 1
		stroke.ApplyStrokeMode = Enum.ApplyStrokeMode.Border
		stroke.LineJoinMode = Enum.LineJoinMode.Round
		stroke.Parent = parent
		return stroke
	end

	local function addGradient(parent)
		local gradient = Instance.new("UIGradient")
		gradient.Color = ColorSequence.new({
			ColorSequenceKeypoint.new(0, AccentColor),
			ColorSequenceKeypoint.new(1, Color3.fromRGB(120, 120, 255))
		})
		gradient.Parent = parent
		return gradient
	end

