		Button.BackgroundTransparency = 1
		Button.Size = UDim2.new(1, 0, 1, 0)
		Button.Text = ""
		Button.ZIndex = 15

		local isOpen = false

		local function buildOptions()
			for _, child in ipairs(OptionHolder:GetChildren()) do
				if child:IsA("TextButton") then
					child:Destroy()
				end
			end
			
			for _, opt in ipairs(options) do
				local OptBtn = Instance.new("TextButton")
				local UICorner_Opt = Instance.new("UICorner")

				OptBtn.Name = opt
				OptBtn.Parent = OptionHolder
				OptBtn.BackgroundColor3 = Color3.fromRGB(22, 22, 22)
				OptBtn.BorderSizePixel = 0
				OptBtn.Size = UDim2.new(0.95, 0, 0, 32)
				OptBtn.Font = Enum.Font.GothamMedium
				OptBtn.Text = "   " .. opt
				OptBtn.TextColor3 = TextMuted
				OptBtn.TextSize = 13
				OptBtn.TextXAlignment = Enum.TextXAlignment.Left
				OptBtn.ZIndex = 25

				UICorner_Opt.CornerRadius = UDim.new(0, 4)
				UICorner_Opt.Parent = OptBtn

				OptBtn.MouseButton1Click:Connect(function()
					SelectedLabel.Text = opt
					isOpen = false
					TweenService:Create(OptionHolder, TweenInfo.new(0.2), {Size = UDim2.new(1, 0, 0, 0)}):Play()
					TweenService:Create(ArrowLabel, TweenInfo.new(0.2), {Rotation = 0}):Play()
					task.delay(0.2, function() OptionHolder.Visible = false end)
					if callback then callback(opt) end
				end)

				OptBtn.MouseEnter:Connect(function()
					TweenService:Create(OptBtn, TweenInfo.new(0.1), {BackgroundColor3 = Color3.fromRGB(30, 30, 45)}):Play()
					TweenService:Create(OptBtn, TweenInfo.new(0.1), {TextColor3 = TextMain}):Play()
				end)
				OptBtn.MouseLeave:Connect(function()
					TweenService:Create(OptBtn, TweenInfo.new(0.1), {BackgroundColor3 = Color3.fromRGB(22, 22, 22)}):Play()
					TweenService:Create(OptBtn, TweenInfo.new(0.1), {TextColor3 = TextMuted}):Play()
				end)
			end
		end

		buildOptions()
		local totalHeight = #options * 34 + 4

		Button.MouseButton1Click:Connect(function()
			isOpen = not isOpen
			if isOpen then
				OptionHolder.Visible = true
				OptionHolder.Size = UDim2.new(1, 0, 0, 0)
				TweenService:Create(OptionHolder, TweenInfo.new(0.2, Enum.EasingStyle.Quart), {Size = UDim2.new(1, 0, 0, totalHeight)}):Play()
				TweenService:Create(ArrowLabel, TweenInfo.new(0.2), {Rotation = 180}):Play()
			else
				TweenService:Create(OptionHolder, TweenInfo.new(0.2, Enum.EasingStyle.Quart), {Size = UDim2.new(1, 0, 0, 0)}):Play()
				TweenService:Create(ArrowLabel, TweenInfo.new(0.2), {Rotation = 0}):Play()
				task.delay(0.2, function() OptionHolder.Visible = false end)
			end
		end)

