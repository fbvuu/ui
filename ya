        MobileCard.Visible = (not Main.Visible) and IsMobile
    end)
    MobileCard.MouseButton1Click:Connect(function() Main.Visible = true end)
    MobileCard.TouchTap:Connect(function() Main.Visible = true end)

    -- Drag
    local dragging, dragInput, dragStart, startPos
    local function updateDrag(input)
        local d = input.Position - dragStart
        Main.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset+d.X, startPos.Y.Scale, startPos.Y.Offset+d.Y)
    end
    TopBar.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = true; dragStart = input.Position; startPos = Main.Position
            input.Changed:Connect(function()
                if input.UserInputState == Enum.UserInputState.End then dragging = false end
            end)
        end
    end)
    TopBar.InputChanged:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
            dragInput = input
        end
    end)
    UserInputService.InputChanged:Connect(function(input)
        if input == dragInput and dragging then updateDrag(input) end
    end)

    local tabs = {}

    ------------------------------------------------------------
    -- CreateTab
    ------------------------------------------------------------
    function lib:CreateTab(title, iconId)
        local TabBtn = Instance.new("TextButton")
        TabBtn.Name             = title
        TabBtn.Parent           = Nav
        TabBtn.BackgroundColor3 = T.BG2
        TabBtn.BackgroundTransparency = 1
        TabBtn.Size             = UDim2.new(0.92, 0, 0, IsMobile and 32 or 36)
        TabBtn.Font             = Enum.Font.GothamMedium
        TabBtn.Text             = "  " .. title
        TabBtn.TextColor3       = T.Dim
        TabBtn.TextSize         = IsMobile and 12 or 13
        TabBtn.TextXAlignment   = Enum.TextXAlignment.Left
        TabBtn.AutoButtonColor  = false
        Corner(6, TabBtn)

        -- Left accent bar (hidden until active)
        local Accent = Instance.new("Frame")
        Accent.Name             = "Accent"
        Accent.Parent           = TabBtn
        Accent.BackgroundColor3 = T.White
        Accent.BorderSizePixel  = 0
        Accent.Size             = UDim2.new(0, 2, 0.55, 0)
        Accent.AnchorPoint      = Vector2.new(0, 0.5)
        Accent.Position         = UDim2.new(0, 0, 0.5, 0)
        Accent.BackgroundTransparency = 1
        Corner(2, Accent)

        -- Tab icon
        local Icon
        if iconId then
            Icon = Instance.new("ImageLabel")
            Icon.Parent               = TabBtn
            Icon.BackgroundTransparency = 1
            Icon.Position             = UDim2.new(0, 6, 0.5, -8)
            Icon.Size                 = UDim2.new(0, 16, 0, 16)
            Icon.Image                = iconId
            Icon.ImageTransparency    = 0.5
            TabBtn.Text               = "        " .. title
        end

        local TabFrame = Instance.new("Frame")
        TabFrame.Name               = title .. "_Frame"
        TabFrame.Parent             = ContentContainer
        TabFrame.Size               = UDim2.new(1,0,1,0)
        TabFrame.BackgroundTransparency = 1
        TabFrame.Visible            = false

        -- SubTab bar (horizontal pills at top of content)
        local SubTabBar = Instance.new("ScrollingFrame")
        SubTabBar.Name               = "SubTabBar"
        SubTabBar.Parent             = TabFrame
        SubTabBar.BackgroundTransparency = 1
        SubTabBar.ScrollBarThickness = 0
        SubTabBar.Size               = UDim2.new(1, 0, 0, IsMobile and 30 or 34)
        SubTabBar.AutomaticCanvasSize = Enum.AutomaticSize.X
        SubTabBar.CanvasSize         = UDim2.new(0,0,0,0)

        local STLayout = Instance.new("UIListLayout")
        STLayout.Parent            = SubTabBar
        STLayout.FillDirection     = Enum.FillDirection.Horizontal
        STLayout.SortOrder         = Enum.SortOrder.LayoutOrder
        STLayout.VerticalAlignment = Enum.VerticalAlignment.Center
        STLayout.Padding           = UDim.new(0, 6)

        local STPad = Instance.new("UIPadding")
        STPad.Parent      = SubTabBar
        STPad.PaddingLeft = UDim.new(0, 10)

        -- Subtab separator line
        local STSep = Instance.new("Frame")
        STSep.Parent           = TabFrame
        STSep.BackgroundColor3 = T.Border
        STSep.BorderSizePixel  = 0
        STSep.Position         = UDim2.new(0, 0, 0, IsMobile and 30 or 34)
        STSep.Size             = UDim2.new(1, 0, 0, 1)

        local ElementsContainer = Instance.new("Frame")
        ElementsContainer.Name               = "ElementsContainer"
        ElementsContainer.Parent             = TabFrame
        ElementsContainer.BackgroundTransparency = 1
        ElementsContainer.Position           = UDim2.new(0, 0, 0, IsMobile and 31 or 35)
        ElementsContainer.Size               = UDim2.new(1, 0, 1, -(IsMobile and 31 or 35))

        table.insert(tabs, {Button = TabBtn, Frame = TabFrame, Icon = Icon, Accent = Accent})

        TabBtn.MouseButton1Click:Connect(function()
            for _, t in ipairs(tabs) do
                TweenService:Create(t.Button, TweenInfo.new(0.15), {BackgroundTransparency = 1, TextColor3 = T.Dim}):Play()
                TweenService:Create(t.Accent, TweenInfo.new(0.15), {BackgroundTransparency = 1}):Play()
                if t.Icon then TweenService:Create(t.Icon, TweenInfo.new(0.15), {ImageTransparency = 0.5}):Play() end
                t.Frame.Visible = false
            end
            TweenService:Create(TabBtn, TweenInfo.new(0.15), {BackgroundTransparency = 0.7, TextColor3 = T.White}):Play()
            TweenService:Create(Accent, TweenInfo.new(0.15), {BackgroundTransparency = 0}):Play()
            if Icon then TweenService:Create(Icon, TweenInfo.new(0.15), {ImageTransparency = 0}):Play() end
            TabFrame.Visible = true
        end)

        if #tabs == 1 then
            TabFrame.Visible = true
            TabBtn.BackgroundTransparency = 0.7
            TabBtn.TextColor3 = T.White
            Accent.BackgroundTransparency = 0
            if Icon then Icon.ImageTransparency = 0 end
        end

        local TabObject = { Container = ElementsContainer, TabBar = SubTabBar, SubTabs = {} }

        --------------------------------------------------------
        -- CreateSubTab
        --------------------------------------------------------
        function TabObject:CreateSubTab(subTitle)
            local SubBtn = Instance.new("TextButton")
            SubBtn.Name               = subTitle
            SubBtn.Parent             = self.TabBar
            SubBtn.BackgroundColor3   = T.BG3
            SubBtn.BackgroundTransparency = 1
            SubBtn.AutomaticSize      = Enum.AutomaticSize.X
            SubBtn.Size               = UDim2.new(0, 0, 0, IsMobile and 24 or 26)
            SubBtn.Font               = Enum.Font.GothamMedium
            SubBtn.Text               = "  " .. subTitle .. "  "
            SubBtn.TextColor3         = T.Dim
            SubBtn.TextSize           = IsMobile and 11 or 12
            SubBtn.AutoButtonColor    = false
            Corner(5, SubBtn)

            local SubCanvas = Instance.new("ScrollingFrame")
            SubCanvas.Name                = subTitle .. "_Canvas"
            SubCanvas.Parent              = self.Container
            SubCanvas.BackgroundTransparency = 1
            SubCanvas.Size                = UDim2.new(1, 0, 1, 0)
            SubCanvas.ScrollBarThickness  = 2
            SubCanvas.ScrollBarImageColor3 = T.Border
            SubCanvas.AutomaticCanvasSize = Enum.AutomaticSize.Y
            SubCanvas.Visible             = false

            local SubList = Instance.new("UIListLayout")
            SubList.Parent              = SubCanvas
            SubList.HorizontalAlignment = Enum.HorizontalAlignment.Center
            SubList.SortOrder           = Enum.SortOrder.LayoutOrder
            SubList.Padding             = UDim.new(0, 6)

            local SubPad = Instance.new("UIPadding")
            SubPad.Parent        = SubCanvas
            SubPad.PaddingTop    = UDim.new(0, 8)
            SubPad.PaddingBottom = UDim.new(0, 12)

            table.insert(self.SubTabs, {Button = SubBtn, Canvas = SubCanvas})

            SubBtn.MouseButton1Click:Connect(function()
                for _, st in ipairs(self.SubTabs) do
                    TweenService:Create(st.Button, TweenInfo.new(0.15), {BackgroundTransparency = 1, TextColor3 = T.Dim}):Play()
                    st.Canvas.Visible = false
                end
                TweenService:Create(SubBtn, TweenInfo.new(0.15), {BackgroundTransparency = 0, TextColor3 = T.White}):Play()
                SubCanvas.Visible = true
            end)

            if #self.SubTabs == 1 then
                SubCanvas.Visible = true
                SubBtn.BackgroundTransparency = 0
                SubBtn.TextColor3 = T.White
            end

            return SubCanvas
        end

