	-- Dragging Functionality
	local dragging, dragInput, dragStart, startPos
	local function update(input)
		local delta = input.Position - dragStart
		Main.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
	end

	TopBar.InputBegan:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
			dragging = true
			dragStart = input.Position
			startPos = Main.Position
			input.Changed:Connect(function()
				if input.UserInputState == Enum.UserInputState.End then
					dragging = false
				end
			end)
		end
	end)

	TopBar.InputChanged:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
			dragInput = input
		end
	end)

	UserInputService.InputChanged:Connect(function(input)
		if input == dragInput and dragging then
			update(input)
		end
	end)

	local mDragging, mDragInput, mDragStart, mStartPos
	local function updateMobile(input)
		local delta = input.Position - mDragStart
		MobileCard.Position = UDim2.new(mStartPos.X.Scale, mStartPos.X.Offset + delta.X, mStartPos.Y.Scale, mStartPos.Y.Offset + delta.Y)
	end

	MobileCard.InputBegan:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
			mDragging = true
			mDragStart = input.Position
			mStartPos = MobileCard.Position
			input.Changed:Connect(function()
				if input.UserInputState == Enum.UserInputState.End then
					mDragging = false
				end
			end)
		end
	end)

	MobileCard.InputChanged:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
			mDragInput = input
		end
	end)

	UserInputService.InputChanged:Connect(function(input)
		if input == mDragInput and mDragging then
			updateMobile(input)
		end
	end)

	local tabs = {}

	function lib:CreateTab(title, iconId)
		local TabBtn = Instance.new("TextButton")
		local UICorner_Tab = Instance.new("UICorner")
		local Icon = Instance.new("ImageLabel")
		local TabFrame = Instance.new("Frame")
		
		-- Dynamic Watermark/Back Label behind the active tab
		local BackLabel = Instance.new("TextLabel")

		local SubTabBar = Instance.new("ScrollingFrame")
		local SubTabListLayout = Instance.new("UIListLayout")
		local SubTabPadding = Instance.new("UIPadding")
		local ElementsContainer = Instance.new("Frame")

		TabBtn.Name = title
		TabBtn.Parent = Navigation
		TabBtn.BackgroundColor3 = Color3.fromRGB(25, 25, 25)
		TabBtn.BackgroundTransparency = 1.000
		TabBtn.Size = UDim2.new(0.9, 0, 0, IsMobile and 32 or 35)
		TabBtn.Font = Enum.Font.GothamMedium
		TabBtn.Text = "   " .. title
		TabBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
		TabBtn.TextSize = IsMobile and 12 or 14
		TabBtn.TextTransparency = 0.5
		TabBtn.TextXAlignment = Enum.TextXAlignment.Left
		TabBtn.AutoButtonColor = false

		UICorner_Tab.CornerRadius = UDim.new(0, 6)
		UICorner_Tab.Parent = TabBtn

		if iconId then
			Icon.Parent = TabBtn
			Icon.BackgroundTransparency = 1.000
			Icon.Position = UDim2.new(0, IsMobile and 7 or 10, 0.5, -8)
			Icon.Size = UDim2.new(0, IsMobile and 15 or 16, 0, IsMobile and 15 or 16)
			Icon.Image = iconId
			Icon.ImageTransparency = 0.5
			TabBtn.Text = "         " .. title
		end

		TabFrame.Name = title .. "_Frame"
		TabFrame.Parent = ContentContainer
		TabFrame.Size = UDim2.new(1, 0, 1, 0)
		TabFrame.BackgroundTransparency = 1
		TabFrame.Visible = false

		-- Watermark Back Label
		BackLabel.Name = "BackLabel"
		BackLabel.Parent = TabFrame
		BackLabel.BackgroundTransparency = 1
		BackLabel.Position = UDim2.new(0.04, 0, 0.05, 0)
		BackLabel.Size = UDim2.new(0.92, 0, 0, 45)
		BackLabel.Font = Enum.Font.GothamBold
		BackLabel.Text = string.upper(title)
		BackLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
		BackLabel.TextSize = 34
		BackLabel.TextTransparency = 0.94
		BackLabel.TextXAlignment = Enum.TextXAlignment.Left
		BackLabel.ZIndex = 1

		SubTabBar.Name = "SubTabBar"
		SubTabBar.Parent = TabFrame
		SubTabBar.BackgroundTransparency = 1
		SubTabBar.Size = UDim2.new(1, 0, 0, IsMobile and 32 or 35)
		SubTabBar.ScrollBarThickness = 0
		SubTabBar.CanvasSize = UDim2.new(2, 0, 0, 0)

		SubTabListLayout.Parent = SubTabBar
		SubTabListLayout.FillDirection = Enum.FillDirection.Horizontal
		SubTabListLayout.SortOrder = Enum.SortOrder.LayoutOrder
		SubTabListLayout.Padding = UDim.new(0, 20)

		SubTabPadding.Parent = SubTabBar
		SubTabPadding.PaddingLeft = UDim.new(0, 20)
		SubTabPadding.PaddingTop = UDim.new(0, 10)

		ElementsContainer.Name = "ElementsContainer"
		ElementsContainer.Parent = TabFrame
		ElementsContainer.BackgroundTransparency = 1
		ElementsContainer.Position = UDim2.new(0, 0, 0, IsMobile and 34 or 40)
		ElementsContainer.Size = UDim2.new(1, 0, 1, -(IsMobile and 34 or 40))

		table.insert(tabs, {Button = TabBtn, Frame = TabFrame, Icon = Icon})

		TabBtn.MouseButton1Click:Connect(function()
			for _, t in ipairs(tabs) do
				TweenService:Create(t.Button, TweenInfo.new(0.2), {BackgroundTransparency = 1, TextTransparency = 0.5}):Play()
				if t.Icon then
					TweenService:Create(t.Icon, TweenInfo.new(0.2), {ImageTransparency = 0.5}):Play()
				end
				t.Frame.Visible = false
			end
			TweenService:Create(TabBtn, TweenInfo.new(0.2), {BackgroundTransparency = 0.5, TextTransparency = 0}):Play()
			if iconId then
				TweenService:Create(Icon, TweenInfo.new(0.2), {ImageTransparency = 0}):Play()
			end
			TabFrame.Visible = true
		end)

		local TabObject = {
			Container = ElementsContainer,
			TabBar = SubTabBar,
			SubTabs = {}
		}

		function TabObject:CreateSubTab(subTitle)
			local SubBtn = Instance.new("TextButton")
			local IndicatorLine = Instance.new("Frame")
			local SubCanvas = Instance.new("ScrollingFrame")
			local SubList = Instance.new("UIListLayout")
			local SubPad = Instance.new("UIPadding")

			SubBtn.Name = subTitle
			SubBtn.Parent = self.TabBar
			SubBtn.BackgroundTransparency = 1
			SubBtn.Size = UDim2.new(0, 0, 1, 0)
			SubBtn.AutomaticSize = Enum.AutomaticSize.X
			SubBtn.Font = Enum.Font.GothamMedium
			SubBtn.Text = subTitle
			SubBtn.TextColor3 = Color3.fromRGB(200, 200, 200)
			SubBtn.TextSize = 14.000

			IndicatorLine.Parent = SubBtn
			IndicatorLine.BackgroundColor3 = AccentColor
			IndicatorLine.BorderSizePixel = 0
			IndicatorLine.Position = UDim2.new(0, 0, 1, -2)
			IndicatorLine.Size = UDim2.new(1, 0, 0, 2)
			IndicatorLine.BackgroundTransparency = 1

			SubCanvas.Name = subTitle .. "_Canvas"
			SubCanvas.Parent = self.Container
			SubCanvas.BackgroundTransparency = 1
			SubCanvas.Size = UDim2.new(1, 0, 1, 0)
			SubCanvas.ScrollBarThickness = 0
			SubCanvas.AutomaticCanvasSize = Enum.AutomaticSize.Y
			SubCanvas.Visible = false

			SubList.Parent = SubCanvas
			SubList.HorizontalAlignment = Enum.HorizontalAlignment.Center
			SubList.SortOrder = Enum.SortOrder.LayoutOrder
			SubList.Padding = UDim.new(0, 8)

			SubPad.Parent = SubCanvas
			SubPad.PaddingTop = UDim.new(0, 5)
			SubPad.PaddingBottom = UDim.new(0, 15)

			table.insert(self.SubTabs, {Button = SubBtn, Canvas = SubCanvas, Line = IndicatorLine})

			SubBtn.MouseButton1Click:Connect(function()
				for _, st in ipairs(self.SubTabs) do
					st.Canvas.Visible = false
					TweenService:Create(st.Button, TweenInfo.new(0.2), {TextColor3 = Color3.fromRGB(200, 200, 200)}):Play()
					TweenService:Create(st.Line, TweenInfo.new(0.2), {BackgroundTransparency = 1}):Play()
				end
				SubCanvas.Visible = true
				TweenService:Create(SubBtn, TweenInfo.new(0.2), {TextColor3 = Color3.fromRGB(255, 255, 255)}):Play()
				TweenService:Create(IndicatorLine, TweenInfo.new(0.2), {BackgroundTransparency = 0}):Play()
			end)

			if #self.SubTabs == 1 then
				SubCanvas.Visible = true
				SubBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
				IndicatorLine.BackgroundTransparency = 0
			end

			return SubCanvas
		end

		if #tabs == 1 then
			TabFrame.Visible = true
			TabBtn.BackgroundTransparency = 0.5
			TabBtn.TextTransparency = 0
			if iconId then Icon.ImageTransparency = 0 end
		end

		return TabObject
	end

	function lib:CreateToggle(title, ParentCanvas, callback)
		local ToggleFrame = Instance.new("Frame")
		local UICorner_Toggle = Instance.new("UICorner")
		local TitleLabel = Instance.new("TextLabel")
		local Pill = Instance.new("Frame")
		local PillCorner = Instance.new("UICorner")
		local Indicator = Instance.new("Frame")
		local IndicatorCorner = Instance.new("UICorner")
		local Button = Instance.new("TextButton")

		ToggleFrame.Name = "Toggle"
		ToggleFrame.Parent = ParentCanvas
		ToggleFrame.BackgroundColor3 = ElementBG
		ToggleFrame.BackgroundTransparency = 0.15
		ToggleFrame.Size = UDim2.new(0.95, 0, 0, IsMobile and 40 or 45)

		UICorner_Toggle.CornerRadius = UDim.new(0, 6)
		UICorner_Toggle.Parent = ToggleFrame
		local stroke = addStroke(ToggleFrame, ElementBorder, 1)

		TitleLabel.Name = "Title"
		TitleLabel.Parent = ToggleFrame
		TitleLabel.BackgroundTransparency = 1.000
		TitleLabel.Position = UDim2.new(0, 10, 0, 0)
		TitleLabel.Size = UDim2.new(0.7, 0, 1, 0)
		TitleLabel.Font = Enum.Font.GothamMedium
		TitleLabel.Text = title
		TitleLabel.TextColor3 = TextMuted
		TitleLabel.TextSize = IsMobile and 13 or 14
		TitleLabel.TextXAlignment = Enum.TextXAlignment.Left

		Pill.Name = "Pill"
		Pill.Parent = ToggleFrame
		Pill.BackgroundColor3 = Color3.fromRGB(35, 35, 35)
		Pill.Position = UDim2.new(1, -(IsMobile and 50 or 55), 0.5, -(IsMobile and 9 or 10))
		Pill.Size = UDim2.new(0, IsMobile and 36 or 40, 0, IsMobile and 18 or 20)

		PillCorner.CornerRadius = UDim.new(1, 0)
		PillCorner.Parent = Pill

		Indicator.Name = "Indicator"
		Indicator.Parent = Pill
		Indicator.BackgroundColor3 = Color3.fromRGB(200, 200, 200)
		Indicator.Position = UDim2.new(0, 2, 0.5, 0)
		Indicator.Size = UDim2.new(0, IsMobile and 14 or 16, 0, IsMobile and 14 or 16)
		Indicator.AnchorPoint = Vector2.new(0, 0.5)

		IndicatorCorner.CornerRadius = UDim.new(1, 0)
		IndicatorCorner.Parent = Indicator

		Button.Parent = ToggleFrame
		Button.BackgroundTransparency = 1
		Button.Size = UDim2.new(1, 0, 1, 0)
		Button.Text = ""

		local active = false

		local ToggleObject = {}
		function ToggleObject:Set(state)
			active = state
			if active then
				TweenService:Create(Indicator, TweenInfo.new(0.2), {Position = UDim2.new(1, -18, 0.5, 0), BackgroundColor3 = Color3.fromRGB(255, 255, 255)}):Play()
				TweenService:Create(Pill, TweenInfo.new(0.2), {BackgroundColor3 = AccentColor}):Play()
				TweenService:Create(TitleLabel, TweenInfo.new(0.2), {TextColor3 = TextMain}):Play()
				TweenService:Create(stroke, TweenInfo.new(0.2), {Color = AccentColor}):Play()
			else
				TweenService:Create(Indicator, TweenInfo.new(0.2), {Position = UDim2.new(0, 2, 0.5, 0), BackgroundColor3 = Color3.fromRGB(200, 200, 200)}):Play()
				TweenService:Create(Pill, TweenInfo.new(0.2), {BackgroundColor3 = Color3.fromRGB(35, 35, 35)}):Play()
				TweenService:Create(TitleLabel, TweenInfo.new(0.2), {TextColor3 = TextMuted}):Play()
				TweenService:Create(stroke, TweenInfo.new(0.2), {Color = ElementBorder}):Play()
			end
			callback(active)
		end
		
		function ToggleObject:Get()
			return active
		end

		Button.MouseButton1Click:Connect(function()
			ToggleObject:Set(not active)
		end)

		ToggleFrame.MouseEnter:Connect(function()
			TweenService:Create(ToggleFrame, TweenInfo.new(0.2), {BackgroundColor3 = ElementBGHover}):Play()
			if not active then
				TweenService:Create(stroke, TweenInfo.new(0.2), {Color = ElementBorderHover}):Play()
			end
		end)

		ToggleFrame.MouseLeave:Connect(function()
			TweenService:Create(ToggleFrame, TweenInfo.new(0.2), {BackgroundColor3 = ElementBG}):Play()
			if not active then
				TweenService:Create(stroke, TweenInfo.new(0.2), {Color = ElementBorder}):Play()
			end
		end)

		return ToggleObject
	end

	function lib:CreateButton(title, ParentCanvas, callback)
		local ButtonFrame = Instance.new("Frame")
		local UICorner_Btn = Instance.new("UICorner")
		local TitleLabel = Instance.new("TextLabel")
		local Button = Instance.new("TextButton")
		local ArrowLabel = Instance.new("TextLabel")

		ButtonFrame.Name = "Button"
		ButtonFrame.Parent = ParentCanvas
		ButtonFrame.BackgroundColor3 = ElementBG
		ButtonFrame.BackgroundTransparency = 0.15
		ButtonFrame.Size = UDim2.new(0.95, 0, 0, IsMobile and 40 or 45)

		UICorner_Btn.CornerRadius = UDim.new(0, 6)
		UICorner_Btn.Parent = ButtonFrame
		local stroke = addStroke(ButtonFrame, ElementBorder, 1)

		TitleLabel.Name = "Title"
		TitleLabel.Parent = ButtonFrame
		TitleLabel.BackgroundTransparency = 1
		TitleLabel.Position = UDim2.new(0, 10, 0, 0)
		TitleLabel.Size = UDim2.new(0.85, 0, 1, 0)
		TitleLabel.Font = Enum.Font.GothamMedium
		TitleLabel.Text = title
		TitleLabel.TextColor3 = TextMuted
		TitleLabel.TextSize = IsMobile and 13 or 14
		TitleLabel.TextXAlignment = Enum.TextXAlignment.Left

		ArrowLabel.Parent = ButtonFrame
		ArrowLabel.BackgroundTransparency = 1
		ArrowLabel.Position = UDim2.new(1, -35, 0, 0)
		ArrowLabel.Size = UDim2.new(0, 25, 1, 0)
		ArrowLabel.Font = Enum.Font.GothamBold
		ArrowLabel.Text = "›"
		ArrowLabel.TextColor3 = AccentColor
		ArrowLabel.TextSize = 22

		Button.Parent = ButtonFrame
		Button.BackgroundTransparency = 1
		Button.Size = UDim2.new(1, 0, 1, 0)
		Button.Text = ""

		local function clickAnimation()
			local origSize = UDim2.new(0.95, 0, 0, IsMobile and 40 or 45)
			local pressSize = UDim2.new(0.93, 0, 0, IsMobile and 38 or 43)
			
			TweenService:Create(ButtonFrame, TweenInfo.new(0.08, Enum.EasingStyle.Quart, Enum.EasingDirection.Out), {
				Size = pressSize,
				BackgroundColor3 = Color3.fromRGB(25, 25, 40)
			}):Play()
			TweenService:Create(TitleLabel, TweenInfo.new(0.08), {TextColor3 = TextMain}):Play()

			task.delay(0.08, function()
				TweenService:Create(ButtonFrame, TweenInfo.new(0.15, Enum.EasingStyle.Quart, Enum.EasingDirection.Out), {
					Size = origSize,
