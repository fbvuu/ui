    ------------------------------------------------------------
    -- CreateToggle
    ------------------------------------------------------------
    function lib:CreateToggle(title, ParentCanvas, callback)
        local Frame = Instance.new("Frame")
        Frame.Name             = "Toggle"
        Frame.Parent           = ParentCanvas
        Frame.BackgroundColor3 = T.BG3
        Frame.BorderSizePixel  = 0
        Frame.Size             = UDim2.new(0.94, 0, 0, IsMobile and 38 or 42)
        Corner(6, Frame)
        Stroke(1, T.Border, Frame)

        local Lbl = Instance.new("TextLabel")
        Lbl.Name               = "Title"
        Lbl.Parent             = Frame
        Lbl.BackgroundTransparency = 1
        Lbl.Position           = UDim2.new(0, 10, 0, 0)
        Lbl.Size               = UDim2.new(0.72, 0, 1, 0)
        Lbl.Font               = Enum.Font.GothamMedium
        Lbl.Text               = title
        Lbl.TextColor3         = T.Dim
        Lbl.TextSize           = IsMobile and 11 or 12
        Lbl.TextXAlignment     = Enum.TextXAlignment.Left

        -- Pill track
        local TrackW = IsMobile and 34 or 38
        local TrackH = IsMobile and 18 or 20
        local Pill = Instance.new("Frame")
        Pill.Parent           = Frame
        Pill.BackgroundColor3 = T.Track
        Pill.BorderSizePixel  = 0
        Pill.AnchorPoint      = Vector2.new(1, 0.5)
        Pill.Position         = UDim2.new(1, -10, 0.5, 0)
        Pill.Size             = UDim2.new(0, TrackW, 0, TrackH)
        Corner(TrackH, Pill)
        Stroke(1, T.Border, Pill)

        local Dot = Instance.new("Frame")
        Dot.Parent           = Pill
        Dot.BackgroundColor3 = T.Dim
        Dot.BorderSizePixel  = 0
        Dot.AnchorPoint      = Vector2.new(0, 0.5)
        Dot.Position         = UDim2.new(0, 2, 0.5, 0)
        Dot.Size             = UDim2.new(0, TrackH-4, 0, TrackH-4)
        Corner(TrackH, Dot)

        local HitBtn = Instance.new("TextButton")
        HitBtn.Parent             = Frame
        HitBtn.BackgroundTransparency = 1
        HitBtn.Size               = UDim2.new(1,0,1,0)
        HitBtn.Text               = ""

        local active = false
        local Obj = {}

        function Obj:Set(state)
            active = state
            if active then
                TweenService:Create(Dot, TweenInfo.new(0.18), {Position = UDim2.new(1, -(TrackH-2), 0.5, 0), BackgroundColor3 = T.White}):Play()
                TweenService:Create(Pill, TweenInfo.new(0.18), {BackgroundColor3 = Color3.fromRGB(50,50,50)}):Play()
                TweenService:Create(Lbl, TweenInfo.new(0.18), {TextColor3 = T.White}):Play()
            else
                TweenService:Create(Dot, TweenInfo.new(0.18), {Position = UDim2.new(0, 2, 0.5, 0), BackgroundColor3 = T.Dim}):Play()
                TweenService:Create(Pill, TweenInfo.new(0.18), {BackgroundColor3 = T.Track}):Play()
                TweenService:Create(Lbl, TweenInfo.new(0.18), {TextColor3 = T.Dim}):Play()
            end
            if callback then callback(active) end
        end

        function Obj:Get() return active end

        HitBtn.MouseButton1Click:Connect(function() Obj:Set(not active) end)
        HitBtn.TouchTap:Connect(function() Obj:Set(not active) end)
        return Obj
    end

