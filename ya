    ------------------------------------------------------------
    function lib:CreateSlider(title, ParentCanvas, min, max, default, callback)
        local Frame = Instance.new("Frame")
        Frame.Name             = "Slider"
        Frame.Parent           = ParentCanvas
        Frame.BackgroundColor3 = T.BG3
        Frame.BorderSizePixel  = 0
        Frame.Size             = UDim2.new(0.94, 0, 0, IsMobile and 50 or 56)
        Corner(6, Frame)
        Stroke(1, T.Border, Frame)

        local Lbl = Instance.new("TextLabel")
        Lbl.Name               = "Title"
        Lbl.Parent             = Frame
        Lbl.BackgroundTransparency = 1
        Lbl.Position           = UDim2.new(0, 10, 0, 0)
        Lbl.Size               = UDim2.new(0.62, 0, 0, IsMobile and 26 or 30)
        Lbl.Font               = Enum.Font.GothamMedium
        Lbl.Text               = title
        Lbl.TextColor3         = T.OffWhite
        Lbl.TextSize           = IsMobile and 11 or 12
        Lbl.TextXAlignment     = Enum.TextXAlignment.Left

        local ValLbl = Instance.new("TextLabel")
        ValLbl.Name               = "Value"
        ValLbl.Parent             = Frame
        ValLbl.BackgroundTransparency = 1
        ValLbl.AnchorPoint        = Vector2.new(1, 0)
        ValLbl.Position           = UDim2.new(1, -10, 0, 0)
        ValLbl.Size               = UDim2.new(0, 40, 0, IsMobile and 26 or 30)
        ValLbl.Font               = Enum.Font.GothamBold
        ValLbl.Text               = tostring(default)
        ValLbl.TextColor3         = T.White
        ValLbl.TextSize           = IsMobile and 11 or 12
        ValLbl.TextXAlignment     = Enum.TextXAlignment.Right

        local trackY = IsMobile and 34 or 38
        local TrackBG = Instance.new("Frame")
        TrackBG.Parent           = Frame
        TrackBG.BackgroundColor3 = T.Track
        TrackBG.BorderSizePixel  = 0
        TrackBG.Position         = UDim2.new(0, 10, 0, trackY)
        TrackBG.Size             = UDim2.new(1, -20, 0, 4)
        Corner(4, TrackBG)

        local FillBar = Instance.new("Frame")
        FillBar.Name             = "Fill"
        FillBar.Parent           = TrackBG
        FillBar.BackgroundColor3 = T.Fill
        FillBar.BorderSizePixel  = 0
        FillBar.Size             = UDim2.new(0, 0, 1, 0)
        Corner(4, FillBar)

        local Handle = Instance.new("Frame")
        Handle.Parent           = TrackBG
        Handle.BackgroundColor3 = T.White
        Handle.BorderSizePixel  = 0
        Handle.AnchorPoint      = Vector2.new(0.5, 0.5)
        Handle.Position         = UDim2.new(0, 0, 0.5, 0)
        Handle.Size             = UDim2.new(0, 13, 0, 13)
        Corner(13, Handle)
        Stroke(1, T.Border, Handle)

        local HitBtn = Instance.new("TextButton")
        HitBtn.Parent             = Frame
        HitBtn.BackgroundTransparency = 1
        HitBtn.Size               = UDim2.new(1,0,1,0)
        HitBtn.Text               = ""
        HitBtn.ZIndex             = 5

        local current = default
        local dragging = false

        local function update(pct)
            pct = math.clamp(pct, 0, 1)
            current = min + pct * (max - min)
            FillBar.Size = UDim2.new(pct, 0, 1, 0)
            Handle.Position = UDim2.new(pct, 0, 0.5, 0)
            local disp = math.floor(current * 10 + 0.5) / 10
            ValLbl.Text = tostring(disp)
            if callback then callback(disp) end
        end

        local function processInput(input)
            local tx = TrackBG.AbsolutePosition.X
            local tw = TrackBG.AbsoluteSize.X
            update((input.Position.X - tx) / tw)
        end

        HitBtn.InputBegan:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
                dragging = true; processInput(input)
            end
        end)
        UserInputService.InputChanged:Connect(function(input)
            if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
                processInput(input)
            end
        end)
        UserInputService.InputEnded:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
                dragging = false
            end
        end)

        update((default - min) / (max - min))

        local Obj = {}
        function Obj:Set(val)
            current = math.clamp(val, min, max)
            update((current - min) / (max - min))
        end
        function Obj:Get() return current end
        return Obj
    end

