		TitleLabel.Name = "Title"
		TitleLabel.Parent = SliderFrame
		TitleLabel.BackgroundTransparency = 1
		TitleLabel.Position = UDim2.new(0, 10, 0, 0)
		TitleLabel.Size = UDim2.new(0.6, 0, 0, IsMobile and 26 or 28)
		TitleLabel.Font = Enum.Font.GothamMedium
		TitleLabel.Text = title
		TitleLabel.TextColor3 = TextMuted
		TitleLabel.TextSize = IsMobile and 13 or 14
		TitleLabel.TextXAlignment = Enum.TextXAlignment.Left

		ValueLabel.Name = "Value"
		ValueLabel.Parent = SliderFrame
		ValueLabel.BackgroundTransparency = 1
		ValueLabel.Position = UDim2.new(1, -50, 0, 0)
		ValueLabel.Size = UDim2.new(0, 40, 0, 28)
		ValueLabel.Font = Enum.Font.GothamMedium
		ValueLabel.Text = tostring(default)
		ValueLabel.TextColor3 = AccentColor
		ValueLabel.TextSize = 13
		ValueLabel.TextXAlignment = Enum.TextXAlignment.Right

		TrackBack.Name = "TrackBack"
		TrackBack.Parent = SliderFrame
		TrackBack.BackgroundColor3 = Color3.fromRGB(35, 35, 35)
		TrackBack.BorderSizePixel = 0
		TrackBack.Position = UDim2.new(0, 10, 0, IsMobile and 32 or 38)
		TrackBack.Size = UDim2.new(1, -20, 0, 4)

		UICorner_Track.CornerRadius = UDim.new(1, 0)
		UICorner_Track.Parent = TrackBack

		Fill.Name = "Fill"
		Fill.Parent = TrackBack
		Fill.BackgroundColor3 = AccentColor
		Fill.BorderSizePixel = 0
		Fill.Size = UDim2.new(0, 0, 1, 0)

		UICorner_Fill.CornerRadius = UDim.new(1, 0)
		UICorner_Fill.Parent = Fill

		Handle.Name = "Handle"
		Handle.Parent = TrackBack
		Handle.BackgroundColor3 = TextMain
		Handle.BorderSizePixel = 0
		Handle.AnchorPoint = Vector2.new(0.5, 0.5)
		Handle.Position = UDim2.new(0, 0, 0.5, 0)
		Handle.Size = UDim2.new(0, 12, 0, 12)

		UICorner_Handle.CornerRadius = UDim.new(1, 0)
		UICorner_Handle.Parent = Handle
		addStroke(Handle, ElementBorder, 1)

		Button.Parent = SliderFrame
		Button.BackgroundTransparency = 1
		Button.Size = UDim2.new(1, 0, 1, 0)
		Button.Text = ""
		Button.ZIndex = 5

		local currentValue = default
		local isDragging = false

		local function updateSlider(customPct)
			local pct = customPct or math.clamp((currentValue - min) / (max - min), 0, 1)
			Fill.Size = UDim2.new(pct, 0, 1, 0)
			Handle.Position = UDim2.new(pct, 0, 0.5, 0)
			local displayValue = math.floor(currentValue * 10 + 0.5) / 10
			ValueLabel.Text = tostring(displayValue)
			if callback then callback(displayValue) end
		end

		local function processInput(input)
			local trackX = TrackBack.AbsolutePosition.X
			local trackW = TrackBack.AbsoluteSize.X
			local pct = math.clamp((input.Position.X - trackX) / trackW, 0, 1)
			currentValue = min + pct * (max - min)
			updateSlider(pct)
		end

		Button.InputBegan:Connect(function(input)
			if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
				isDragging = true
				TweenService:Create(Handle, TweenInfo.new(0.15), {Size = UDim2.new(0, 15, 0, 15)}):Play()
				processInput(input)
			end
		end)

		UserInputService.InputChanged:Connect(function(input)
			if isDragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
				processInput(input)
			end
		end)

		UserInputService.InputEnded:Connect(function(input)
			if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
				isDragging = false
				TweenService:Create(Handle, TweenInfo.new(0.15), {Size = UDim2.new(0, 12, 0, 12)}):Play()
			end
		end)

		SliderFrame.MouseEnter:Connect(function()
			TweenService:Create(SliderFrame, TweenInfo.new(0.2), {BackgroundColor3 = ElementBGHover}):Play()
			TweenService:Create(stroke, TweenInfo.new(0.2), {Color = ElementBorderHover}):Play()
			TweenService:Create(TitleLabel, TweenInfo.new(0.2), {TextColor3 = TextMain}):Play()
		end)

		SliderFrame.MouseLeave:Connect(function()
			TweenService:Create(SliderFrame, TweenInfo.new(0.2), {BackgroundColor3 = ElementBG}):Play()
			TweenService:Create(stroke, TweenInfo.new(0.2), {Color = ElementBorder}):Play()
			TweenService:Create(TitleLabel, TweenInfo.new(0.2), {TextColor3 = TextMuted}):Play()
		end)

		currentValue = default
		updateSlider()

		local SliderObject = {}
		function SliderObject:Set(val)
			currentValue = math.clamp(val, min, max)
			updateSlider()
		end
		
		function SliderObject:Get()
			return currentValue
		end
		return SliderObject
	end

