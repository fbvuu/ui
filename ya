			TweenService:Create(DropFrame, TweenInfo.new(0.2), {BackgroundColor3 = ElementBGHover}):Play()
			TweenService:Create(stroke, TweenInfo.new(0.2), {Color = ElementBorderHover}):Play()
			TweenService:Create(TitleLabel, TweenInfo.new(0.2), {TextColor3 = TextMain}):Play()
		end)

		DropFrame.MouseLeave:Connect(function()
			TweenService:Create(DropFrame, TweenInfo.new(0.2), {BackgroundColor3 = ElementBG}):Play()
			TweenService:Create(stroke, TweenInfo.new(0.2), {Color = ElementBorder}):Play()
			TweenService:Create(TitleLabel, TweenInfo.new(0.2), {TextColor3 = TextMuted}):Play()
		end)

		local DropdownObject = {}
		function DropdownObject:Set(value)
			SelectedLabel.Text = value
			if callback then callback(value) end
		end
		
		function DropdownObject:Get()
			return SelectedLabel.Text
		end

		function DropdownObject:Refresh(newOptions, newCallback)
			if newCallback then callback = newCallback end
			options = newOptions
			buildOptions()
			totalHeight = #options * 34 + 4
			SelectedLabel.Text = options[1] or ""
		end

		return DropdownObject
	end

